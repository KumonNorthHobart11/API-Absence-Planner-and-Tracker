{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
  }
  },
  "AllowedHosts": "*",
  "Firebase": {
    "ProjectId": "YOUR_FIREBASE_PROJECT_ID",
    "DatabaseId": "(default)"
  },
  "Jwt": {
    "Secret": "YOUR_JWT_SECRET_MIN_32_CHARACTERS_LONG",
    "Issuer": "AbsencePlannerAPI",
    "Audience": "AbsencePlannerClient",
    "ExpirationMinutes": 60
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "YOUR_SMTP_USERNAME",
    "Password": "YOUR_SMTP_APP_PASSWORD",
    "FromEmail": "YOUR_FROM_EMAIL",
    "FromName": "Absence Planner"
  },
  "Twilio": {
    "AccountSid": "YOUR_TWILIO_ACCOUNT_SID",
    "AuthToken": "YOUR_TWILIO_AUTH_TOKEN",
    "FromNumber": "YOUR_TWILIO_FROM_NUMBER"
  },
  "Otp": {
    "ExpiryMinutes": 10,
    "SuperAdminOtp": "YOUR_SUPER_ADMIN_OTP"
  },
  "App": {
    "SeedVersion": 3
  },
  "Cors": {
    "AllowedOrigins": [
      "https://yourdomain.com",
   "https://www.yourdomain.com"
    ]
  }
}
